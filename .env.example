# Chave do Gemini (provider padrão). Pegue em https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Chave da Claude/Anthropic. Usada se RT_PROVIDER=claude e, com o Gemini de padrão,
# como fallback automático quando o Gemini fica indisponível (erro 503).
ANTHROPIC_API_KEY=

# Provider do LLM: "gemini" (padrão) ou "claude"
RT_PROVIDER=gemini

# JID do dono (quem pode usar os comandos "!carol on/off/lock/unlock/status")
OWNER_JID=

# Chats onde a CARol responde (JIDs separados por vírgula).
# Vazio = responde em QUALQUER chat. Em produção, liste só os chats liberados.
# Ex.: RT_CHATS=5571999999999@s.whatsapp.net,120363000000000000@g.us
RT_CHATS=

# Ajustes finos (opcionais)
RT_MODELO_GEMINI=gemini-2.5-flash-lite
RT_MODELO_CLAUDE=claude-haiku-4-5
RT_MAX_HISTORICO=5
RT_MAX_TOKENS=400
RT_DELAY_MS=10000
RT_INTERVALO_MIN_MS=0
